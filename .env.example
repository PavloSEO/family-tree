# Copy to `.env` in the repository root and set your values.
# Used by `docker compose` and the local server (see `docs/11-deployment.md`).

# --- Required for Docker Compose and production ---
# Empty value: `docker compose` will not start the service (see docker-compose.yml).
# At least 32 characters for login to work; generate: openssl rand -hex 32
JWT_SECRET=

# --- First admin (seed when the database has no users) ---
ADMIN_LOGIN=admin
ADMIN_PASSWORD=

# --- HTTP ---
PORT=3000

# --- Client (Vite): API base URL; empty = same origin; in dev, Vite proxies `/api` to PORT ---
# VITE_API_BASE_URL=

# --- CSP (server only): if the SPA calls the API from another origin, list it here (space-separated), otherwise connect-src will block fetch ---
# CSP_CONNECT_SRC_EXTRA=https://api.example.com

# --- SQLite (local path or path inside the container) ---
# Default in Docker: /data/db/family-tree.db
DATABASE_PATH=
# Alias for DATABASE_PATH (see docs/11-deployment.md)
DB_PATH=

# --- Optional: migrations directory (if not next to dist/serve.js) ---
# MIGRATIONS_PATH=

# 1 = skip auto-seed on server start (migrations still run). Admin must already exist (seed-cli / API).
# SKIP_DB_SEED=1

# --- Reserved for later use ---
# mainPhoto files directory, etc. (local default: `<cwd>/data/photos`)
PHOTOS_PATH=
# tar.gz backups directory (local default: `<cwd>/data/backups`; in Docker: /data/backups)
BACKUPS_PATH=
# Docker image only: 1 = daily cron (03:00) + delete backups older than 30 days (see docs/11-deployment.md)
# ENABLE_BACKUP_CRON=0
# SESSION_TTL_DAYS=30
# MAX_UPLOAD_SIZE_MB=10
# Rate limit for POST /api/auth/login per IP (see docs/07-auth.md)
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_MINUTES=15
# Limit POST/PUT/PATCH/DELETE on /api/* (except POST /api/auth/login) per IP, in-memory
# API_MUTATE_RATE_LIMIT_MAX=400
# API_MUTATE_RATE_LIMIT_WINDOW_MINUTES=15
