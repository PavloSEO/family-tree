# Скопируйте в `.env` в корне репозитория и подставьте свои значения.
# Используется `docker compose` и локальный сервер (см. `docs/11-deployment.md`).

# --- Обязательно для Docker Compose и production ---
# Пустое значение: `docker compose` не запустит сервис (см. docker-compose.yml).
# Минимум 32 символа для работы логина на сервере; генерация: openssl rand -hex 32
JWT_SECRET=

# --- Первый admin (seed при пустой БД) ---
ADMIN_LOGIN=admin
ADMIN_PASSWORD=

# --- HTTP ---
PORT=3000

# --- Клиент (Vite): база API; пусто = тот же origin, в dev — proxy `/api` на PORT ---
# VITE_API_BASE_URL=

# --- CSP (только сервер): если SPA ходит на API с другого origin, перечислите его здесь (через пробел), иначе connect-src заблокирует fetch ---
# CSP_CONNECT_SRC_EXTRA=https://api.example.com

# --- SQLite (локально или путь в контейнере) ---
# В Docker по умолчанию: /data/db/family-tree.db
DATABASE_PATH=
# Алиас к DATABASE_PATH (как в docs/11-deployment.md)
DB_PATH=

# --- Опционально: каталог миграций (если не рядом с dist/serve.js) ---
# MIGRATIONS_PATH=

# 1 = не вызывать автосид при старте сервера (миграции всё равно выполняются). Нужен уже созданный admin (seed-cli / API).
# SKIP_DB_SEED=1

# --- Зарезервировано под следующие этапы ---
# Каталог файлов mainPhoto и др. (локально по умолчанию `<cwd>/data/photos`)
PHOTOS_PATH=
# Каталог tar.gz бэкапов (локально по умолчанию `<cwd>/data/backups`; в Docker: /data/backups)
BACKUPS_PATH=
# Только Docker-образ: 1 = ежедневный cron (3:00) + удаление бэкапов старше 30 дней (см. docs/11-deployment.md)
# ENABLE_BACKUP_CRON=0
# SESSION_TTL_DAYS=30
# MAX_UPLOAD_SIZE_MB=10
# Лимит POST /api/auth/login по IP (см. `docs/07-auth.md`)
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_MINUTES=15
# Лимит POST/PUT/PATCH/DELETE на /api/* (кроме POST /api/auth/login) по IP, in-memory
# API_MUTATE_RATE_LIMIT_MAX=400
# API_MUTATE_RATE_LIMIT_WINDOW_MINUTES=15
